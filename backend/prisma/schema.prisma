// Skema database Populi WA Survey. Lihat docs/ARCHITECTURE.md §5.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  superadmin
  admin
  viewer
}

enum SurveyStatus {
  draft
  active
  closed
}

enum BlastStatus {
  pending
  scheduled
  running
  completed
  failed
}

enum RecipientStatus {
  queued
  sent
  delivered
  read
  failed
}

enum Direction {
  in
  out
}

model User {
  id           String   @id @default(cuid())
  name         String
  username     String   @unique
  email        String?
  passwordHash String
  role         Role     @default(admin)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
}

model Survey {
  id              String       @id @default(cuid())
  title           String
  description     String?
  status          SurveyStatus @default(draft)
  triggerEnabled  Boolean      @default(false) // mulai survei otomatis bila pesan masuk cocok kata kunci
  triggerKeywords String[]     @default([]) // kata kunci pemicu (mis. "isi survey", "survei")
  createdAt       DateTime     @default(now())
  questions       Question[]
  blasts          Blast[]
  responses       SurveyResponse[]
}

model Question {
  id       String  @id @default(cuid())
  surveyId String
  survey   Survey  @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  type     String  @default("text") // text | rating | number | choice | boolean | image
  text     String
  order    Int     @default(0)
  required Boolean @default(true)
  options  Json? // konfig per tipe: rating {min,max}, choice {choices:[...]}
  answers  Answer[]
}

model Segment {
  id        String           @id @default(cuid())
  name      String
  createdAt DateTime         @default(now())
  contacts  SegmentContact[]
  blasts    Blast[]
}

model Contact {
  id            String           @id @default(cuid())
  phone         String           @unique // E.164, mis. 628xxxxxxxxx
  name          String?
  attributes    Json?
  subscribed    Boolean          @default(true) // false = opt-out (dikecualikan dari blast)
  optOutAt      DateTime? // kapan kontak menyatakan berhenti
  consentSource String? // sumber persetujuan: manual | import | inbound | form
  consentAt     DateTime?
  createdAt     DateTime         @default(now())
  segments      SegmentContact[]
  messages      Message[]
  recipients    BlastRecipient[]
  responses     SurveyResponse[]
}

model SegmentContact {
  segmentId String
  contactId String
  segment   Segment @relation(fields: [segmentId], references: [id], onDelete: Cascade)
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@id([segmentId, contactId])
}

model Blast {
  id             String           @id @default(cuid())
  surveyId       String?
  survey         Survey?          @relation(fields: [surveyId], references: [id], onDelete: SetNull)
  segmentId      String?
  segment        Segment?         @relation(fields: [segmentId], references: [id], onDelete: SetNull)
  vendor         String // "meta" | "qontak"
  templateName   String?
  templateLang   String           @default("id")
  messageText    String? // teks/preview pesan (untuk audit)
  status         BlastStatus      @default(pending)
  scheduledAt    DateTime?
  sentCount      Int              @default(0)
  deliveredCount Int              @default(0)
  readCount      Int              @default(0)
  failedCount    Int              @default(0)
  createdAt      DateTime         @default(now())
  recipients     BlastRecipient[]
  responses      SurveyResponse[]
}

model BlastRecipient {
  id              String          @id @default(cuid())
  blastId         String
  blast           Blast           @relation(fields: [blastId], references: [id], onDelete: Cascade)
  contactId       String
  contact         Contact         @relation(fields: [contactId], references: [id], onDelete: Cascade)
  vendor          String
  vendorMessageId String?         @unique
  status          RecipientStatus @default(queued)
  error           String?
  updatedAt       DateTime        @updatedAt
  createdAt       DateTime        @default(now())

  @@index([blastId])
  @@index([vendorMessageId])
}

model Message {
  id              String    @id @default(cuid())
  contactId       String?
  contact         Contact?  @relation(fields: [contactId], references: [id], onDelete: SetNull)
  direction       Direction
  vendor          String
  vendorMessageId String?
  text            String?
  payload         Json?
  createdAt       DateTime  @default(now())

  @@index([contactId])
  @@index([vendorMessageId])
}

model SurveyResponse {
  id          String    @id @default(cuid())
  surveyId    String
  survey      Survey    @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  contactId   String
  contact     Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  blastId     String?
  blast       Blast?    @relation(fields: [blastId], references: [id], onDelete: SetNull)
  currentStep Int       @default(0) // indeks pertanyaan berikutnya (untuk alur chat)
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  answers     Answer[]

  @@index([contactId])
}

model Answer {
  id         String         @id @default(cuid())
  responseId String
  response   SurveyResponse @relation(fields: [responseId], references: [id], onDelete: Cascade)
  questionId String
  question   Question       @relation(fields: [questionId], references: [id], onDelete: Cascade)
  value      String
  createdAt  DateTime       @default(now())
}

model VendorConfig {
  id          String   @id @default(cuid())
  vendor      String   @unique // "meta" | "qontak"
  isDefault   Boolean  @default(false)
  active      Boolean  @default(true)
  credentials String? // JSON terenkripsi (AES-256-GCM)
  updatedAt   DateTime @updatedAt
}

model AutoReplyRule {
  id        String   @id @default(cuid())
  name      String
  matchType String   @default("contains") // contains | exact | starts
  keyword   String
  response  String
  enabled   Boolean  @default(true)
  priority  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([enabled])
}

model AiConfig {
  id           String   @id // singleton: "default"
  enabled      Boolean  @default(false)
  provider     String   @default("anthropic") // anthropic | openai | gemini | custom
  model        String   @default("claude-haiku-4-5-20251001")
  baseUrl      String? // untuk provider custom (OpenAI-compatible)
  systemPrompt String   @default("Anda asisten layanan pelanggan via WhatsApp. Jawab singkat, ramah, dan jelas dalam Bahasa Indonesia.")
  apiKey       String? // terenkripsi (AES-256-GCM)
  updatedAt    DateTime @updatedAt
}

model WebhookLog {
  id        String   @id @default(cuid())
  vendor    String
  event     String
  status    String // success | failed | ignored
  payload   Json?
  note      String?
  createdAt DateTime @default(now())

  @@index([vendor])
  @@index([createdAt])
}

// Template pesan WhatsApp (harus disetujui Meta sebelum dipakai broadcast).
// Disimpan lokal sebagai draf/arsip; status approval dikelola manual mengikuti Meta.
model MessageTemplate {
  id             String   @id @default(cuid())
  name           String // nama template (snake_case, sesuai Meta)
  category       String   @default("MARKETING") // MARKETING | UTILITY | AUTHENTICATION
  language       String   @default("id") // id | en_US | ...
  headerType     String   @default("none") // none | text | image | document | video
  headerText     String? // dipakai bila headerType = text
  headerMediaUrl String? // contoh URL media (gambar/dokumen/video) untuk preview & sampel approval
  bodyText       String // isi utama, boleh berisi variabel {{1}} {{2}}
  footerText     String?
  buttons        Json? // [{type:"QUICK_REPLY"|"URL"|"PHONE_NUMBER", text, url?, phone?}]
  sampleParams   String[] @default([]) // contoh nilai untuk {{1}}, {{2}} (untuk preview & submit ke Meta)
  status         String   @default("draft") // draft | submitted | approved | rejected (lokal, ikuti status Meta)
  useCase        String? // survei | rilis | acara | lainnya
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// Kebijakan pengiriman (anti-banned): batas harian + jitter antar pesan (warm-up).
model SendingPolicy {
  id          String   @id // singleton: "default"
  enabled     Boolean  @default(true)
  dailyLimit  Int      @default(500) // maks pesan keluar / hari (naikkan bertahap saat warm-up)
  jitterMinMs Int      @default(800) // jeda acak min antar pesan
  jitterMaxMs Int      @default(2500) // jeda acak maks antar pesan
  updatedAt   DateTime @updatedAt
}
